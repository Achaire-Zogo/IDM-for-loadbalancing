<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.0"?>

<!--
-->

<plugin>

   <extension point="org.eclipse.ui.newWizards">
      <!-- @generated loadbalancer -->
      <category
            id="org.eclipse.emf.ecore.Wizard.category.ID"
            name="%_UI_Wizard_category"/>
      <wizard
            id="loadbalancer.presentation.LoadbalancerModelWizardID"
            name="%_UI_LoadbalancerModelWizard_label"
            class="loadbalancer.presentation.LoadbalancerModelWizard"
            category="org.eclipse.emf.ecore.Wizard.category.ID"
            icon="icons/full/obj16/LoadbalancerModelFile.gif">
         <description>%_UI_LoadbalancerModelWizard_description</description>
         <selection class="org.eclipse.core.resources.IResource"/>
      </wizard>
   </extension>

   <extension point="org.eclipse.ui.editors">
      <!-- @generated loadbalancer -->
      <editor
            id="loadbalancer.presentation.LoadbalancerEditorID"
            name="%_UI_LoadbalancerEditor_label"
            icon="icons/full/obj16/LoadbalancerModelFile.gif"
            extensions="loadbalancer"
            class="loadbalancer.presentation.LoadbalancerEditor"
            contributorClass="loadbalancer.presentation.LoadbalancerActionBarContributor">
      </editor>
   </extension>

</plugin>
